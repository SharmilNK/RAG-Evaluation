# Firecrawl
FIRECRAWL_API_KEY=

# SerpAPI
SERPAPI_API_KEY=

# LLM provider selection: gemini | openai
VITELIS_LLM_PROVIDER=gemini
VITELIS_EMBED_PROVIDER=local

# Gemini / Google AI Studio (recommended for free-tier usage)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
VITELIS_RAGAS_DISABLED=true

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VITELIS_OPENAI_MIN_DELAY=5.0

# Langfuse (optional)
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
